# ========================================
# bitter-sql Configuration
# ========================================

# SECURITY NOTE:
# For security, passwords MUST be provided via this .env file or interactive mode.
# CLI password options have been removed to prevent passwords from appearing in shell history.

# ========================================
# Database Creation (bitter-sql create)
# ========================================

# Database name (required for non-interactive mode)
db_name=my_database.db

# Encryption password (optional, leave empty for unencrypted database)
# IMPORTANT: Never commit this file with real passwords to version control!
password=

# Encryption cipher (optional, defaults to 'sqlcipher' if password is provided)
# Options: sqlcipher, chacha20, aes256cbc, aes128cbc, rc4
# Recommended: sqlcipher (best tool compatibility, industry standard)
cipher=sqlcipher

# Enable verbose logging (optional)
verbose=false

# Path to custom SQL schema file (optional)
schema_path=

# ========================================
# Database Rekeying (bitter-sql rekey)
# ========================================

# Current password (required for non-interactive rekey)
current_password=

# New password (required for non-interactive rekey)
new_password=

# ========================================
# Security Best Practices
# ========================================
# 1. Add .env to .gitignore (already done in this project)
# 2. Use different passwords for development and production
# 3. Use interactive mode when possible for maximum security
# 4. Consider using SQLCipher (default) for best tool compatibility
